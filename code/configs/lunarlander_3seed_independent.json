{
  "env_name": "LunarLander-v3",
  "task_description": "Black-box control task. Maximize the original environment return and reach the target evaluation score without using hand-written environment semantics.",
  "task_description_path": "contexts/lunarlander/task_description.txt",
  "step_source_path": "contexts/lunarlander/step_masked.py",
  "mask_official_reward": true,
  "method": "fdre_hrdc",
  "llm_provider": "deepseek",
  "llm_model": "deepseek-chat",
  "max_iterations": 10,
  "total_timesteps": 1000000,
  "eval_episodes": 20,
  "target_score": 200.0,
  "reward_clip": 10.0,
  "reward_error_fallback": "original",
  "reward_repair_attempts": 3,
  "num_seeds": 10,
  "feedback_mode": "diagnostic",
  "reward_structure": "hrdc",
  "training_algorithm": "ppo",
  "ppo_learning_rate": 0.00025,
  "ppo_n_steps": 1024,
  "ppo_batch_size": 64,
  "ppo_n_epochs": 4,
  "ppo_gamma": 0.999,
  "ppo_gae_lambda": 0.98,
  "ppo_clip_range": 0.2,
  "ppo_ent_coef": 0.01,
  "ppo_vf_coef": 0.5,
  "ppo_max_grad_norm": 0.5,
  "ppo_n_envs": 4,
  "ppo_verbose": 1,
  "min_original_reward_anchor": 0.5,
  "allow_original_reward_in_reward": false,
  "domain_knowledge_guard": true,
  "forbidden_reward_terms": "OFFICIAL_REWARD_MASKED,masked_reward,prev_shaping",
  "restart_after_bad_iterations": 5,
  "restart_score_threshold": 0.0,
  "rollback_min_score": 0.0,
  "shared_reward_pool_path": "",
  "shared_pool_min_score": null,
  "force_iterations_before_patience": 4,
  "patience": 8,
  "output_dir": "outputs/lunarlander_10seed_1M_final"
}
